# Variables para bettermode-top-comentaristas.php
# (el script también las lee del .env de la raíz del repo si ya existen ahí)

# Endpoint GraphQL de Bettermode. US: https://api.bettermode.com  | EU: el de eu-central-1
BETTERMODE_API_URL=https://api.bettermode.com

# ID del network (diez.5t4d10.com). Requerida.
BETTERMODE_NETWORK_ID=

# Opción A: token Bearer de app ya emitido (si lo tienes, es lo más simple/estable).
BETTERMODE_APP_TOKEN=

# Opción B (fallback): si NO hay APP_TOKEN, el script hace login admin como el resto
# del proyecto (guest token -> loginNetwork). Requiere estas tres:
BETTERMODE_NETWORK_DOMAIN=diez.5t4d10.com
BETTERMODE_ADMIN_EMAIL=
BETTERMODE_ADMIN_PASSWORD=
